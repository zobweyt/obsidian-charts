filters:
  and:
    - file.inFolder("Examples/Daily")
properties:
  note.temperature:
    displayName: Temperature (°C)
views:
  - type: chart
    name: Last entries
    order:
      - temperature
    sort: []
    chartType: line
    colors:
      - var(--color-purple)
    showPoints: true
    showXLine: true
    xLineStyle: dashed
    xLineWidth: 0.5
    yLineWidth: 0.5
    lineWidth: 2
    showLegend: true
    yMin: "34"
    yMax: "42"
    showLabels: true
