{
  "tasks": {
    "dev": "scripts/build --watch",
    "build": "scripts/build",
    "clean": "rm -rf dist sandbox/.obsidian",
    "prepare": "git config core.hooksPath scripts/git/hooks"
  },
  "imports": {
    "obsidian": "npm:obsidian@1.10.3"
  },
  "fmt": {
    "exclude": ["*.md"]
  },
  "exclude": ["dist/", "sandbox/"],
  "compilerOptions": {
    "lib": ["dom", "es2022"]
  }
}
