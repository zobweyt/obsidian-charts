{
  "tasks": {
    "build": "deno run -A ./scripts/build.ts",
    "prepare": "git config core.hooksPath ./scripts/git/hooks"
  },
  "imports": {
    "obsidian": "npm:obsidian@1.10.3"
  },
  "fmt": {
    "exclude": ["*.md"]
  },
  "exclude": ["sandbox/", "dist/"],
  "allowScripts": ["npm:classic-level@3.0.0"],
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["deno.ns", "node", "dom"]
  }
}
