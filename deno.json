{
  "tasks": {
    "build": "deno run -A ./scripts/build.ts",
    "watch": "deno run -A ./scripts/build.ts --watch"
  },
  "imports": {
    "echarts": "npm:echarts@6.0.0",
    "obsidian": "npm:obsidian@1.11.0"
  },
  "scopes": {
    "./scripts/": {
      "esbuild": "npm:esbuild@0.28.0"
    }
  },
  "compilerOptions": {
    "lib": ["deno.ns", "node", "dom"],
    "baseUrl": "."
  },
  "nodeModulesDir": "auto"
}
