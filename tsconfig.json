{
  "compilerOptions": {
    "noImplicitAny": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "5.0",
    "rootDir": ".",
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["dom", "es2022"],
    "target": "es2022",
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": []
}
